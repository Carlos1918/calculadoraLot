<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/card_bg"
    android:layout_margin="6dp" android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/tv_pair" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textSize="16sp" android:textColor="#000000" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_direction" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="6dp">
        <TextView android:id="@+id/tv_pips" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textSize="13sp" android:textColor="#6B7280"/>
        <TextView android:id="@+id/tv_result" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="4dp">
        <TextView android:id="@+id/tv_date" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textSize="11sp" android:textColor="#9CA3AF"/>
        <TextView android:id="@+id/btn_delete" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="✕"
            android:textColor="#DC2626" android:textSize="16sp" android:padding="4dp"/>
    </LinearLayout>
</LinearLayout>