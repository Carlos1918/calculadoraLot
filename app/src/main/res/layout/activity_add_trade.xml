<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#FFFFFF">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PAR" android:textSize="11sp" android:textColor="#000000"
            android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinner_pair" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="@drawable/input_bg"
            android:padding="12dp" android:layout_marginBottom="16dp"
            android:popupBackground="#FFFFFF"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DIRECCIÓN" android:textSize="11sp" android:textColor="#000000"
            android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinner_direction" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="@drawable/input_bg"
            android:padding="12dp" android:layout_marginBottom="16dp"
            android:popupBackground="#FFFFFF"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LOTE" android:textSize="11sp" android:textColor="#000000"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/input_lot" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="0.01"
                    android:textColor="#000000" android:textColorHint="#999999"
                    android:inputType="numberDecimal" android:background="@drawable/input_bg" android:padding="12dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ENTRADA" android:textSize="11sp" android:textColor="#000000"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/input_entry" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="1.08500"
                    android:textColor="#000000" android:textColorHint="#999999"
                    android:inputType="numberDecimal" android:background="@drawable/input_bg" android:padding="12dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="STOP LOSS" android:textSize="11sp" android:textColor="#000000"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/input_sl" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="1.08300"
                    android:textColor="#000000" android:textColorHint="#999999"
                    android:inputType="numberDecimal" android:background="@drawable/input_bg" android:padding="12dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TAKE PROFIT" android:textSize="11sp" android:textColor="#000000"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/input_tp" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="1.08900"
                    android:textColor="#000000" android:textColorHint="#999999"
                    android:inputType="numberDecimal" android:background="@drawable/input_bg" android:padding="12dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RESULTADO ($)" android:textSize="11sp" android:textColor="#000000"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/input_result" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="+50.00 o -25.00"
                    android:textColor="#000000" android:textColorHint="#999999"
                    android:inputType="numberDecimal|numberSigned" android:background="@drawable/input_bg" android:padding="12dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PIPS" android:textSize="11sp" android:textColor="#000000"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/input_pips" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="+20 o -10"
                    android:textColor="#000000" android:textColorHint="#999999"
                    android:inputType="numberDecimal|numberSigned" android:background="@drawable/input_bg" android:padding="12dp"/>
            </LinearLayout>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="NOTAS (OPCIONAL)" android:textSize="11sp" android:textColor="#000000"
            android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/input_notes" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Observaciones del trade..."
            android:textColor="#000000" android:textColorHint="#999999"
            android:inputType="textMultiLine" android:lines="3"
            android:background="@drawable/input_bg" android:padding="12dp" android:layout_marginBottom="24dp"/>
        <ProgressBar android:id="@+id/progress_saving" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center"
        android:visibility="gone" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_save" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/save"
            android:backgroundTint="#4F46E5" android:textColor="#FFFFFF"
            android:textStyle="bold" android:padding="14dp"/>
    </LinearLayout>
</ScrollView>